{
  "manifestVersion": "5",
  "id": "com.reom.marker-sync",
  "name": "Marker Sync",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "requiredPermissions": {
    "localFileSystem": "request"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "markerSyncPanel",
      "label": {
        "default": "Marker Sync"
      },
      "minimumSize": {
        "width": 320,
        "height": 260
      },
      "maximumSize": {
        "width": 1600,
        "height": 1200
      }
    }
  ]
}
