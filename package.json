{
  "name": "premiere-and-script-timestamp-synchronizer",
  "version": "0.1.0",
  "description": "MVP toolchain to sync timestamps between scripts and Adobe Premiere Pro markers",
  "type": "module",
  "bin": {
    "marker-sync": "./src/cli.js"
  },
  "scripts": {
    "extract": "node ./src/cli.js extract",
    "inject": "node ./src/cli.js inject",
    "test:sanity": "node ./src/cli.js extract --input ./sample/script.txt --output ./sample/out.markers.json --csv ./sample/out.markers.csv --fuzzy"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
